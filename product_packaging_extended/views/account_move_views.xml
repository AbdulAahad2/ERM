<odoo>
    <record id="view_move_form_inherit_delivery" model="ir.ui.view">
        <field name="name">account.move.form.inherit.delivery</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='quantity']" position="after">
                <field name="x_delivered_packaging_qty"
                       string="Delivered Qty"
                       optional="show"
                       readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>