<odoo>
    <record id="view_picking_form_packaging_qty" model="ir.ui.view">
        <field name="name">stock.picking.form.packaging.qty</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='move_ids_without_package']/list//field[@name='product_packaging_id']" position="after">
                <field name="x_packaging_qty"
                       string="Pkg Count"
                       optional="show"
                       digits="[16,2]"
                       invisible="not product_packaging_id"/>
            </xpath>

            <xpath expr="//field[@name='move_ids_without_package']" position="after">
                <div class="text-muted small mt-1 ms-2"
                     invisible="not move_ids_without_package">
                    <i class="fa fa-cubes me-1" title="Packaging Info"/>
                    <strong>Note:</strong> Choosing a Sales/Purchase package will update the
                    <strong>Demand</strong> quantity.
                    Edit <strong>Pkg Count</strong> to change the number of packs.
                </div>
            </xpath>

        </field>
    </record>
</odoo>