<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_purchase_approval" model="ir.module.category">
        <field name="name">Purchase Approval</field>
        <field name="description">Helps manage multi-level purchase approvals.</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_purchase_approval_manager" model="res.groups">
        <field name="name">Approval Manager</field>
        <field name="category_id" ref="module_category_purchase_approval"/>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
        <field name="comment">Managers can reset approval processes and modify configurations.</field>
    </record>
</odoo>