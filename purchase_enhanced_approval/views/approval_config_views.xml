<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_purchase_approval_config_tree" model="ir.ui.view">
        <field name="name">purchase.approval.config.tree</field>
        <field name="model">purchase.approval.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="level"/>
                <field name="name"/>
                <field name="approver_id"/>
                <field name="approver_group_id" optional="hide"/>
                <field name="min_amount" optional="show"/>
                <field name="max_amount" optional="show"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_purchase_approval_config_form" model="ir.ui.view">
        <field name="name">purchase.approval.config.form</field>
        <field name="model">purchase.approval.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g., Level 1 - Department Manager"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="level"/>
                            <field name="sequence"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="approver_id" options="{'no_create': True}"/>
                            <field name="approver_group_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Amount Conditions (Optional)">
                        <group>
                            <field name="min_amount"/>
                        </group>
                        <group>
                            <field name="max_amount"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_purchase_approval_config_search" model="ir.ui.view">
        <field name="name">purchase.approval.config.search</field>
        <field name="model">purchase.approval.config</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="level"/>
                <field name="approver_id"/>
                <field name="approver_group_id"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Level" name="group_by_level" context="{'group_by': 'level'}"/>
                    <filter string="Approver" name="group_by_approver" context="{'group_by': 'approver_id'}"/>
                    <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_purchase_approval_config" model="ir.actions.act_window">
        <field name="name">Approval Configuration</field>
        <field name="res_model">purchase.approval.config</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_purchase_approval_config"
              name="Approval Configuration"
              parent="purchase.menu_purchase_config"
              action="action_purchase_approval_config"
              sequence="50"/>
</odoo>
