<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_purchase_approval_history_tree" model="ir.ui.view">
        <field name="name">purchase.approval.history.tree</field>
        <field name="model">purchase.approval.history</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="po_name"/>
                <field name="partner_id"/>
                <field name="amount_total" widget="monetary"/>
                <field name="level"/>
                <field name="approver_id"/>
                <field name="approval_date"/>
                <field name="action" widget="badge" 
                       decoration-success="action == 'approved'"
                       decoration-danger="action == 'rejected'"/>
                <field name="notes"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_purchase_approval_history_form" model="ir.ui.view">
        <field name="name">purchase.approval.history.form</field>
        <field name="model">purchase.approval.history</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="purchase_order_id"/>
                            <field name="po_name"/>
                            <field name="partner_id"/>
                            <field name="amount_total" widget="monetary"/>
                        </group>
                        <group>
                            <field name="level"/>
                            <field name="approver_id"/>
                            <field name="approval_date"/>
                            <field name="action" widget="badge"/>
                        </group>
                    </group>
                    <field name="notes"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_purchase_approval_history_search" model="ir.ui.view">
        <field name="name">purchase.approval.history.search</field>
        <field name="model">purchase.approval.history</field>
        <field name="arch" type="xml">
            <search>
                <field name="purchase_order_id"/>
                <field name="po_name"/>
                <field name="partner_id"/>
                <field name="approver_id"/>
                <filter string="Approved" name="approved" domain="[('action', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('action', '=', 'rejected')]"/>
                <filter string="Today" name="today" domain="[('approval_date', '>=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[('approval_date', '>=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month" domain="[('approval_date', '>=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Purchase Order" name="group_by_po" context="{'group_by': 'purchase_order_id'}"/>
                    <filter string="Level" name="group_by_level" context="{'group_by': 'level'}"/>
                    <filter string="Approver" name="group_by_approver" context="{'group_by': 'approver_id'}"/>
                    <filter string="Action" name="group_by_action" context="{'group_by': 'action'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'approval_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_purchase_approval_history_pivot" model="ir.ui.view">
        <field name="name">purchase.approval.history.pivot</field>
        <field name="model">purchase.approval.history</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="approval_date" type="row"/>
                <field name="action" type="col"/>
                <field name="amount_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_purchase_approval_history_graph" model="ir.ui.view">
        <field name="name">purchase.approval.history.graph</field>
        <field name="model">purchase.approval.history</field>
        <field name="arch" type="xml">
            <graph type="bar">
                <field name="approval_date" interval="day"/>
                <field name="action"/>
                <field name="amount_total" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Action -->
    <record id="action_purchase_approval_history" model="ir.actions.act_window">
        <field name="name">Approval History</field>
        <field name="res_model">purchase.approval.history</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="context">{'search_default_approved': 1}</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_purchase_approval_history" 
              name="Approval History" 
              parent="purchase.menu_purchase_config"
              action="action_purchase_approval_history" 
              sequence="60"/>
</odoo>
