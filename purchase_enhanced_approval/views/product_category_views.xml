<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_department_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.department.form.inherit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group/group[1]" position="after">
                <group string="Purchase Approvals">
                    <field name="approver_level_1_id"/>
                    <field name="approver_level_2_id"/>
                    <field name="approver_level_3_id"/>
                    <field name="approver_level_4_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>