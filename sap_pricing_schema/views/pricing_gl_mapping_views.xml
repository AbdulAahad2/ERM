<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_pricing_gl_mapping_tree" model="ir.ui.view">
        <field name="name">pricing.gl.mapping.tree</field>
        <field name="model">pricing.gl.mapping</field>
        <field name="arch" type="xml">
            <list string="GL Account Mappings" editable="bottom">
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="condition_type"/>
                <field name="rule_type"/>
                <field name="account_id" options="{'no_create': True}"/>
                <field name="account_key"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_pricing_gl_mapping_form" model="ir.ui.view">
        <field name="name">pricing.gl.mapping.form</field>
        <field name="model">pricing.gl.mapping</field>
        <field name="arch" type="xml">
            <form string="GL Account Mapping">
                <sheet>
                    <group>
                        <group>
                            <field name="condition_type"/>
                            <field name="rule_type"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="account_id" options="{'no_create': True}"/>
                            <field name="account_key"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pricing_gl_mapping_search" model="ir.ui.view">
        <field name="name">pricing.gl.mapping.search</field>
        <field name="model">pricing.gl.mapping</field>
        <field name="arch" type="xml">
            <search string="Search GL Mappings">
                <field name="condition_type"/>
                <field name="rule_type"/>
                <field name="account_id"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_pricing_gl_mapping" model="ir.actions.act_window">
        <field name="name">GL Account Mappings</field>
        <field name="res_model">pricing.gl.mapping</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pricing_gl_mapping_search"/>
    </record>
</odoo>