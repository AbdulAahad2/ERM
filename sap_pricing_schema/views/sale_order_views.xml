<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════════
         PRICING BREAKDOWN POPUP  (waterfall view)
         ═══════════════════════════════════════════════════════════════════════ -->

     <record id="view_pricing_breakdown_line_tree" model="ir.ui.view">
        <field name="name">pricing.breakdown.line.tree</field>
        <field name="model">pricing.breakdown.line</field>
        <field name="arch" type="xml">
            <list string="Pricing Breakdown"
                  create="false" edit="false" delete="false"
                  default_order="step">

                <field name="step"            string="Step"       width="55" optional="hide"/>
                <field name="condition_type"  string="Cond."      width="80" optional="hide"/>
                <field name="name"            string="Description"
                       decoration-bf="line_type == 'subtotal'"/>
                <field name="line_type"       string="Type"       width="90" optional="hide"/>
                <field name="base_amount"     string="Base Price" widget="float"
                       options="{'digits': [16, 4]}"
                       width="110" column_invisible="True"/>
                <field name="applied_value"   string="Rate / Value" widget="float"
                       options="{'digits': [16, 4]}"
                       width="90"/>

                <!--
                    computed_amount:
                    - Use float widget (not monetary) to prevent automatic red colouring
                      of negative values.
                    - 4 decimal places via field digits.
                    - Bold for subtotal rows (decoration-bf).
                    - Subtotal rows now carry the running price value (not 0) — set
                      in _apply_pricing_schema so there is nothing to hide.
                -->
                <field name="computed_amount"
                       string="Amount"
                       widget="float"
                       options="{'digits': [16, 4]}"
                       decoration-bf="line_type == 'subtotal'"
                       width="120"
                       optional="show"/>

                <!--
                    running_price:
                    - Same float / 4-decimal treatment.
                    - Bold for subtotal rows.
                -->
                <field name="running_price"
                       string="Running Price"
                       widget="float"
                       options="{'digits': [16, 4]}"
                       decoration-bf="line_type == 'subtotal'"
                       width="125"/>

                <field name="gl_account_id"   string="GL Account" optional="hide" width="160"/>
                <field name="account_key"     string="Acct Key"   optional="hide" width="80"/>
                <field name="is_statistical"  column_invisible="True"/>
                <field name="rule_type"       column_invisible="True"/>
                <field name="line_type"       column_invisible="True"/>
            </list>
        </field>
    </record>


    <!-- Action to open the breakdown popup (also used by the button) -->
    <record id="action_pricing_breakdown_popup" model="ir.actions.act_window">
        <field name="name">Pricing Breakdown</field>
        <field name="res_model">pricing.breakdown.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_pricing_breakdown_line_tree"/>
        <field name="target">new</field>
        <field name="context">{'create': False, 'edit': False, 'delete': False}</field>
    </record>


    <!-- ═══════════════════════════════════════════════════════════════════════
         SALE ORDER FORM  — top-level SAP pricing header + stat button
         ═══════════════════════════════════════════════════════════════════════ -->

    <record id="view_sale_order_form_inherit_sap" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.sap</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">

            <xpath expr="//div[@class='o_td_label' and @groups='base.group_no_one' and label[@for='date_order']]" position="attributes">
                <attribute name="groups"/>
            </xpath>

            <xpath expr="//field[@name='date_order' and @groups='base.group_no_one']" position="attributes">
                <attribute name="groups"/>
            </xpath>

            <xpath expr="//label[@for='date_order']" position="attributes">
                <attribute name="string">Order Date</attribute>
            </xpath>

            <!-- 2. Target the field directly to override the "Order Date" label used in later states -->
            <xpath expr="//field[@name='date_order']" position="attributes">
                <attribute name="string">Order Date</attribute>
            </xpath>
            <!-- SAP Pricing toggle + schema selector above the standard header -->
            <xpath expr="//sheet//group[@name='sale_header']" position="before">
                <group string="Odoo Pricing" name="sap_pricing_header">
                    <field name="use_sap_pricing" widget="boolean_toggle" string="Odoo Pricing"/>
                    <!-- Invisible: exposes effective_pricing_date to the domain engine -->
                    <field name="effective_pricing_date" invisible="1"/>
                    <field name ="pricing_date"/>
                    <field name="pricing_schema_id"
                           invisible="not use_sap_pricing"
                           domain="[
                               ('is_template', '=', False),
                               ('active', '=', True),
                               '|', ('match_all_customers', '=', True), ('customer_ids', 'in', [partner_id] if partner_id else []),
                               '|', ('date_from', '=', False), ('date_from', '&lt;=', effective_pricing_date),
                           ]"
                           />

                </group>
            </xpath>

            <!-- Smart button: shows active schema name -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_pricing_breakdown"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-calculator"
                        invisible="not use_sap_pricing">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Odoo Pricing</span>
                        <span class="o_stat_value">
                            <field name="pricing_schema_name"/>
                        </span>
                    </div>
                </button>
            </xpath>

            <!-- Extra SAP columns in the order-line list (inline) -->
            <!-- CRITICAL FIX: Added force_save="1" to readonly pricing fields so onchange values persist -->
            <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="after">
                <field name="pricing_schema_id"
                       string="Schema"
                       column_invisible="not parent.use_sap_pricing"
                       options="{'no_create': True}"
                       force_save="1"/>



                <button name="action_show_pricing_breakdown"
                        type="object"
                        icon="fa-list-ol"
                        title="Show Pricing Breakdown"
                        column_invisible="not parent.use_sap_pricing"/>
            </xpath>

            <!-- Full SAP block in the order-line sub-form (expand view) -->
            <xpath expr="//field[@name='order_line']/form//field[@name='price_unit']" position="after">
                <group invisible="not parent.use_sap_pricing"
                       string="Odoo Pricing Breakdown"
                       name="sap_line_breakdown">
                    <field name="mrp_price"        readonly="1" force_save="1"/>
                    <field name="pricing_schema_id" invisible="1" force_save="1"/>
                    <field name="discount_amount"   readonly="1" force_save="1"/>
                    <field name="surcharge_amount"  readonly="1" force_save="1"/>
                    <field name="charge_amount"     readonly="1" force_save="1"/>
                    <field name="final_unit_price"  readonly="1" force_save="1"/>
                    <field name="tax_base_amount"   readonly="1" force_save="1"/>
                </group>
                <group invisible="not parent.use_sap_pricing" name="sap_line_actions">
                    <button name="action_show_pricing_breakdown"
                            string="View Full Breakdown"
                            type="object"
                            class="btn-secondary"
                            icon="fa-list-ol"/>
                </group>
            </xpath>

        </field>
    </record>


    <!-- ═══════════════════════════════════════════════════════════════════════
         SALE ORDER LINE standalone list  (optional — inherits sale line list)
         ═══════════════════════════════════════════════════════════════════════ -->

    <record id="view_sale_order_line_tree_inherit_sap" model="ir.ui.view">
        <field name="name">sale.order.line.tree.inherit.sap</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.view_order_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom_qty']" position="after">
                <field name="mrp_price"       optional="hide" force_save="1"/>
                <field name="discount_amount" optional="hide" force_save="1"/>
                <field name="surcharge_amount" optional="hide" force_save="1"/>
                <field name="final_unit_price" optional="hide" force_save="1"/>
                <field name="total_with_tax"
                   string="Unit Price (incl. Tax)"
                   column_invisible="not parent.use_sap_pricing"
                   readonly="1"
                   force_save="1"
                   optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_form_sap_inherit" model="ir.ui.view">
    <field name="name">account.move.form.sap.inherit</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

        <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='tax_ids']" position="after">
            <field name="sap_tax_amount"
                   string="SAP Tax"
                   optional="show"
                   invisible="not parent.use_sap_pricing"
                   force_save="1"/>
        </xpath>

        <xpath expr="//field[@name='tax_totals']" position="after">
            <field name="sap_tax_total"
                   string="SAP Calculated Tax"
                   invisible="not use_sap_pricing"
                   widget="monetary"
                   options="{'currency_field': 'currency_id'}"/>
        </xpath>

    </field>
</record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SALE ORDER SEARCH — date range + return scenario filters
         ═══════════════════════════════════════════════════════════════════════ -->

    <record id="view_sale_order_search_inherit_sap" model="ir.ui.view">
        <field name="name">sale.order.search.inherit.sap</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">

                <!-- ── Date-range filters ────────────────────────────────── -->
                <separator/>
                <filter string="Today"
                        name="order_today"
                        domain="[('date_order','&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))),
                                  ('date_order','&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)))]"/>
                <filter string="This Week"
                        name="order_this_week"
                        domain="[('date_order','&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d')),
                                  ('date_order','&lt;',  (context_today() - datetime.timedelta(days=context_today().weekday()) + datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Month"
                        name="order_this_month"
                        domain="[('date_order','&gt;=', context_today().strftime('%Y-%m-01')),
                                  ('date_order','&lt;',  (context_today().replace(day=28) + datetime.timedelta(days=4)).replace(day=1).strftime('%Y-%m-%d'))]"/>
                <filter string="This Quarter"
                        name="order_this_quarter"
                        domain="[('date_order','&gt;=', datetime.date(context_today().year, ((context_today().month - 1) // 3) * 3 + 1, 1).strftime('%Y-%m-%d')),
                                  ('date_order','&lt;',  datetime.date(context_today().year, ((context_today().month - 1) // 3) * 3 + 1, 1).strftime('%Y-%m-%d'))]"/>

                <!-- ── SAP Pricing filters ───────────────────────────────── -->
                <separator/>
                <filter string="Uses Odoo Pricing"
                        name="sap_pricing_active"
                        domain="[('use_sap_pricing','=',True)]"/>

                <!-- ── Group by ─────────────────────────────────────────── -->
                <group expand="0" string="Group By">
                    <filter string="Pricing Schema"
                            name="group_by_schema"
                            context="{'group_by': 'pricing_schema_id'}"/>
                    <filter string="Order Month"
                            name="group_by_order_month"
                            context="{'group_by': 'date_order:month'}"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CREDIT NOTE (RETURN) SEARCH — date range filter on refund invoices
         Lets users filter credit notes by invoice_date for return scenarios.
         ═══════════════════════════════════════════════════════════════════════ -->

    <record id="view_account_move_search_sap_refund" model="ir.ui.view">
        <field name="name">account.move.search.sap.refund.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <!-- Quick date-range filters for credit notes / returns -->
                <filter string="Credit Notes – This Month"
                        name="refund_this_month"
                        domain="[('move_type','=','out_refund'),
                                  ('invoice_date','&gt;=', context_today().strftime('%Y-%m-01')),
                                  ('invoice_date','&lt;',  (context_today().replace(day=28) + datetime.timedelta(days=4)).replace(day=1).strftime('%Y-%m-%d'))]"/>
                <filter string="Credit Notes – This Year"
                        name="refund_this_year"
                        domain="[('move_type','=','out_refund'),
                                  ('invoice_date','&gt;=', datetime.date(context_today().year, 1, 1).strftime('%Y-%m-%d')),
                                  ('invoice_date','&lt;',  datetime.date(context_today().year + 1, 1, 1).strftime('%Y-%m-%d'))]"/>
                <filter string="Uses Odoo Pricing"
                        name="refund_sap_pricing"
                        domain="[('use_sap_pricing','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Refund Month"
                            name="group_refund_month"
                            context="{'group_by': 'invoice_date:month'}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
